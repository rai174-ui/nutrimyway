# ============================
# NutriMyWay Admin Server
# Environment Variables for Hostinger Node.js Hosting
# ============================

# --- REQUIRED ---

# Node server port (Hostinger usually sets this automatically, or use 3000)
PORT=3000

# PostgreSQL Database (Supabase connection string)
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string (URI mode)
# Use the "Transaction pooler" mode (port 6543) for best results
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[HOST].pooler.supabase.com:6543/postgres?sslmode=require

# Secret key for JWT token signing (used for admin & super-admin auth)
# Generate a long random string: https://www.random.org/passwords/?num=1&len=64&format=plain&rnd=new
SESSION_SECRET=your-super-secret-long-random-string-here-min-32-chars

# --- EMAIL (Gmail SMTP) ---
# Required for: admin password resets, super-admin login OTP, member registration emails
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_PORT=587

# --- SUPER ADMIN ---
# Email address that has full super-admin access
SUPER_ADMIN_EMAIL=your-super-admin-email@example.com

# --- APP URL ---
# Your production domain (no trailing slash)
# Used in email links (password reset, OTP, etc.)
APP_URL=https://yourdomain.com

# --- OPTIONAL / STORAGE ---
# If using Replit object storage on Hostinger, these won't work (Replit-only).
# Leave blank for now. We will switch to Cloudflare R2 or local disk later.
# PUBLIC_OBJECT_SEARCH_PATHS=
# PRIVATE_OBJECT_DIR=
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=

# --- ADMIN STATIC FILES ---
# Path to the built admin panel files (relative to project root)
# The server serves these at /admin/*
ADMIN_STATIC=./admin

# --- NODE ENV ---
NODE_ENV=production
